# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# The CLI auto-loads .env from the project root. Real environment variables
# take precedence over values here.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model (claude-opus-4-8)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: use an Anthropic-compatible gateway (e.g. an internal LLM Gateway)
# instead of the public Anthropic API. Set the base URL (no trailing /v1).
# ANTHROPIC_BASE_URL=https://your-llm-gateway.example.com
# Auth header the gateway expects: x-api-key (default) or bearer
# ANTHROPIC_AUTH_STYLE=bearer

# ---------------------------------------------------------------------------
# Daily Digest email delivery (separate feature; only needed to SEND digests).
# Recipient address and send time are set in the UI; SMTP secrets live here.
#
# Gmail example (use an App Password, not your normal password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=you@gmail.com
#   SMTP_FROM_NAME=Daily Digest
#   SMTP_SECURITY=starttls        # starttls (default) | ssl | none
# ---------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=Daily Digest
# SMTP_SECURITY=starttls

# --- Gmail IMAP (optional: the "inbox" tracker). Same app password works. ---
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your-app-password

# --- GitHub tracker (optional: higher rate limits / private repos) ---
# GITHUB_TOKEN=ghp_xxx

# --- Google Calendar (optional: read events + push your parsed schedule) ---
# Works with ANY Google account; switch accounts any time by changing these.
# One-time setup: create OAuth creds in Google Cloud Console, then get a refresh
# token (e.g. via https://developers.google.com/oauthplayground with the scope
# https://www.googleapis.com/auth/calendar).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_TIMEZONE=America/New_York
