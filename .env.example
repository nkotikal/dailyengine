# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# The CLI auto-loads .env from the project root. Real environment variables
# take precedence over values here.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model (claude-opus-4-8)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: use an Anthropic-compatible gateway (e.g. an internal LLM Gateway)
# instead of the public Anthropic API. Set the base URL (no trailing /v1).
# ANTHROPIC_BASE_URL=https://your-llm-gateway.example.com
# Auth header the gateway expects: x-api-key (default) or bearer
# ANTHROPIC_AUTH_STYLE=bearer
